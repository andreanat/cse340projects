<h1>Welcome to CSE Motors!</h1>
<%- messages() %>

<section class="hero">
  <div class="hero-text">
    <h2>DMC Delorean</h2>
    <ul>
      <li>3 Cup holders</li>
      <li>Superman doors</li>
      <li>Fuzzy dice</li>
    </ul>
    <a class="own-today" href="#">Own Today</a>
  </div>

  <img src="/images/vehicles/delorean.jpg" alt="Silver DeLorean car">
</section>

<div class="home-sections">
  <section class="reviews">
    <h2>DMC Delorean Reviews</h2>
    <ul>
      <li>"So fast it's almost like traveling in time."</li>
      <li>"Coolest ride on the road."</li>
      <li>"I'm feeling Marty McFly!"</li>
      <li>"The most futuristic ride of our day."</li>
      <li>"80's living and I love it!"</li>
    </ul>
  </section>

  <section class="upgrades" aria-labelledby="upgrades-title">
    <h2 id="upgrades-title">Delorean Upgrades</h2>
    <div class="upgrades-grid">
      <figure class="up-card">
        <div class="up-image-box">
          <img src="/images/upgrades/flux-cap.png" alt="Flux Capacitor">
        </div>
        <figcaption><a href="#">Flux Capacitor</a></figcaption>
      </figure>

      <figure class="up-card">
        <div class="up-image-box">
          <img src="/images/upgrades/flame.jpg" alt="Flame Decals">
        </div>
        <figcaption><a href="#">Flame Decals</a></figcaption>
      </figure>

      <figure class="up-card">
        <div class="up-image-box">
          <img src="/images/upgrades/bumper_sticker.jpg" alt="Bumper Sticker">
        </div>
        <figcaption><a href="#">Bumper Stickers</a></figcaption>
      </figure>

      <figure class="up-card">
        <div class="up-image-box">
          <img src="/images/upgrades/hub-cap.jpg" alt="Hub Caps">
        </div>
        <figcaption><a href="#">Hub Caps</a></figcaption>
      </figure>
    </div>
  </section>
</div>