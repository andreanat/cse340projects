<header class="site-header">
  <div class="container hdr">
    <a class="brand" href="/"><h1>CSE Motors</h1></a>

    <div class="account-nav">
      <% if (locals.loggedin && locals.accountData) { %>
        <a class="account-link" href="/account/">
          Welcome <%= locals.accountData.account_firstname %>
        </a>
        <a class="account-link" href="/account/logout">Logout</a>
      <% } else { %>
        <a class="account-link" href="/account/login">My Account</a>
      <% } %>
    </div>

    <button class="menu-btn" aria-label="Toggle menu" hidden>☰</button>
  </div>
</header>